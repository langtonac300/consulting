<!-- START: WELCOME-INTRO (JS) -->

<script>
(function () {

  /* ===== CONFIG ===== */
  // Bump the version when you want returning visitors to see the intro
  // again (e.g. after shipping the dental tooth-picker feature).
  var rpIntroStorageKey = 'rpIntroSeen_v1';

  /* ===== SETUP ===== */
  var rpIntroOverlay = document.getElementById('rpIntroOverlay');
  if (!rpIntroOverlay) return;

  /* ===== OPEN ===== */
  function rpIntroOpen() {
    rpIntroOverlay.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
  }

  /* ===== CLOSE ===== */
  window.rpIntroClose = function () {
    rpIntroOverlay.classList.remove('is-visible');
    document.body.style.overflow = '';
    try { localStorage.setItem(rpIntroStorageKey, '1'); } catch (e) {}
    if (typeof rpTrackEvent === 'function') {
      rpTrackEvent('Started the demo tour', 3);
    }
  };

  /* ===== REOPEN ===== */
  window.rpIntroReopen = function () { rpIntroOpen(); };

  /* ===== ESC key to close ===== */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && rpIntroOverlay.classList.contains('is-visible')) {
      rpIntroClose();
    }
  });

  /* ===== Click outside modal to close ===== */
  rpIntroOverlay.addEventListener('click', function (e) {
    if (e.target === rpIntroOverlay) rpIntroClose();
  });

  /* ===== Show on first visit ===== */
  try {
    var seen = localStorage.getItem(rpIntroStorageKey);
    if (!seen) setTimeout(rpIntroOpen, 500);
  } catch (e) {
    setTimeout(rpIntroOpen, 500);
  }

})();
</script>

<!-- END: WELCOME-INTRO (JS) -->

