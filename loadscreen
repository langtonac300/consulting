/* START: WELCOME-INTRO STYLES */

/* ---------- Overlay (pure black backdrop with soft blue glow behind modal) ---------- */
.rp-intro-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  background:
    radial-gradient(circle at 50% 50%, rgba(43, 127, 255, 0.15) 0%, transparent 55%),
    rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.4s ease, visibility 0s linear 0.4s;
}
.rp-intro-overlay.is-visible {
  opacity: 1;
  visibility: visible;
  transition: opacity 0.4s ease, visibility 0s linear 0s;
}

/* ---------- Modal card (black, blue radar glow, grid pattern) ---------- */
.rp-intro-modal {
  position: relative;
  background: linear-gradient(180deg, #0A0A0A 0%, #000000 100%);
  border: 1px solid rgba(91, 155, 255, 0.15);
  border-radius: 20px;
  max-width: 600px;
  width: 100%;
  max-height: 92vh;
  overflow: hidden;
  box-shadow:
    0 32px 80px rgba(0, 0, 0, 0.8),
    0 0 0 1px rgba(43, 127, 255, 0.2),
    0 0 100px rgba(43, 127, 255, 0.25);
  transform: translateY(20px) scale(0.96);
  opacity: 0;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  display: flex;
  flex-direction: column;
}
.rp-intro-overlay.is-visible .rp-intro-modal {
  transform: translateY(0) scale(1);
  opacity: 1;
}

/* Subtle grid pattern overlay */
.rp-intro-modal::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(91, 155, 255, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(91, 155, 255, 0.04) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
  mask-image: radial-gradient(ellipse at top, #000 0%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse at top, #000 0%, transparent 75%);
}

/* Top edge blue light accent */
.rp-intro-modal::after {
  content: "";
  position: absolute;
  top: -1px; left: 15%; right: 15%;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--rp-primary-bright) 50%, transparent 100%);
  filter: blur(1px);
  pointer-events: none;
}

/* Scrollable inner wrapper */
.rp-intro-modal-inner {
  position: relative;
  z-index: 1;
  overflow-y: auto;
}
.rp-intro-modal-inner::-webkit-scrollbar { width: 4px; }
.rp-intro-modal-inner::-webkit-scrollbar-thumb { background: rgba(91, 155, 255, 0.15); border-radius: 2px; }

/* ---------- Header ---------- */
.rp-intro-header {
  padding: 34px 32px 8px;
  text-align: center;
}

/* Radar-pulse LIVE badge (blue expanding rings, on-brand signal motif) */
.rp-intro-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.6875rem;
  font-family: var(--rp-font-mono);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #FFFFFF;
  background: rgba(43, 127, 255, 0.12);
  border: 1px solid rgba(43, 127, 255, 0.35);
  padding: 6px 14px 6px 12px;
  border-radius: 999px;
  margin-bottom: 22px;
}
.rp-intro-badge-radar {
  position: relative;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--rp-primary-bright);
  box-shadow: 0 0 6px var(--rp-primary-bright);
  flex-shrink: 0;
}
.rp-intro-badge-radar::before,
.rp-intro-badge-radar::after {
  content: "";
  position: absolute;
  inset: -1px;
  border-radius: 50%;
  border: 1.5px solid var(--rp-primary-bright);
  animation: rpIntroRadarPulse 2.2s ease-out infinite;
  pointer-events: none;
}
.rp-intro-badge-radar::after { animation-delay: 1.1s; }
@keyframes rpIntroRadarPulse {
  0%   { transform: scale(1);   opacity: 0.9; }
  100% { transform: scale(4.5); opacity: 0;   }
}

/* Headline — bold sans-serif, matches ReadyProspect brand typography */
.rp-intro-title {
  font-family: var(--rp-font-display);
  font-size: 2rem;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -0.035em;
  line-height: 1.08;
  margin-bottom: 14px;
}
.rp-intro-title em {
  font-style: normal;
  background: linear-gradient(135deg, var(--rp-primary-glow) 0%, var(--rp-primary-bright) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.rp-intro-subtitle {
  font-size: 0.9375rem;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.55;
  max-width: 460px;
  margin: 0 auto;
  font-weight: 400;
}

/* ---------- Preview cards ---------- */
.rp-intro-previews {
  padding: 22px 24px 8px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.rp-intro-preview {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px;
  background: rgba(255, 255, 255, 0.025);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  transition: background 0.25s, border-color 0.25s;
}
.rp-intro-preview:hover {
  background: rgba(43, 127, 255, 0.08);
  border-color: rgba(43, 127, 255, 0.3);
}
.rp-intro-preview-visual {
  flex-shrink: 0;
  width: 76px;
  height: 76px;
  border-radius: 10px;
  background: linear-gradient(135deg, rgba(43, 127, 255, 0.15) 0%, rgba(0, 82, 204, 0.04) 100%);
  border: 1px solid rgba(43, 127, 255, 0.22);
  position: relative;
  overflow: hidden;
}
.rp-intro-preview-copy {
  flex: 1;
  min-width: 0;
}
.rp-intro-preview-copy strong {
  display: block;
  font-family: var(--rp-font-display);
  font-size: 0.9375rem;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 3px;
  letter-spacing: -0.01em;
}
.rp-intro-preview-copy span {
  display: block;
  font-size: 0.8125rem;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.45;
}

/* ----- Visual #1: Data rows loading (visitor identified) ----- */
.rp-intro-mini-panel {
  position: absolute;
  inset: 10px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
}
.rp-intro-mini-row {
  height: 5px;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 3px;
  overflow: hidden;
  position: relative;
}
.rp-intro-mini-row::after {
  content: "";
  position: absolute;
  top: 0; left: 0; bottom: 0;
  background: linear-gradient(90deg, var(--rp-primary) 0%, var(--rp-primary-glow) 100%);
  border-radius: 3px;
  animation: rpIntroFill 3.5s ease-in-out infinite;
}
.rp-intro-mini-row:nth-child(1)::after { animation-delay: 0.0s; width: 70%; }
.rp-intro-mini-row:nth-child(2)::after { animation-delay: 0.3s; width: 90%; }
.rp-intro-mini-row:nth-child(3)::after { animation-delay: 0.6s; width: 55%; }
.rp-intro-mini-row:nth-child(4)::after { animation-delay: 0.9s; width: 80%; }
@keyframes rpIntroFill {
  0%       { transform: translateX(-100%); }
  40%, 90% { transform: translateX(0);     }
  100%     { transform: translateX(-100%); }
}
.rp-intro-mini-pin {
  position: absolute;
  top: 10px; right: 10px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--rp-primary-bright);
  box-shadow: 0 0 8px var(--rp-primary-bright);
  animation: rpIntroPinPulse 1.6s ease-in-out infinite;
}
@keyframes rpIntroPinPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(43, 127, 255, 0.6), 0 0 8px var(--rp-primary-bright); }
  50%      { box-shadow: 0 0 0 5px rgba(43, 127, 255, 0), 0 0 8px var(--rp-primary-bright); }
}

/* ----- Visual #2: Score gauge (intent scored) ----- */
.rp-intro-mini-score {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
}
.rp-intro-mini-score-num {
  font-family: var(--rp-font-display);
  font-size: 1.625rem;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  letter-spacing: -0.03em;
  animation: rpIntroScoreFade 3.5s ease-in-out infinite;
}
@keyframes rpIntroScoreFade {
  0%, 10%  { opacity: 0.35; }
  60%, 85% { opacity: 1;    }
  100%     { opacity: 0.35; }
}
.rp-intro-mini-score-bar {
  width: 58px;
  height: 4px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2px;
  overflow: hidden;
}
.rp-intro-mini-score-bar::after {
  content: "";
  display: block;
  height: 100%;
  background: linear-gradient(90deg, var(--rp-primary-glow) 0%, var(--rp-primary-bright) 100%);
  border-radius: 2px;
  animation: rpIntroScoreFill 3.5s ease-in-out infinite;
  box-shadow: 0 0 8px rgba(43, 127, 255, 0.5);
}
@keyframes rpIntroScoreFill {
  0%   { width: 0%;  }
  55%  { width: 87%; }
  85%  { width: 87%; }
  100% { width: 0%;  }
}
.rp-intro-mini-score-label {
  font-size: 0.5rem;
  font-family: var(--rp-font-mono);
  font-weight: 700;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.35);
  text-transform: uppercase;
  margin-top: 2px;
}

/* ----- Visual #3: Ad platform grid (ads activated) ----- */
.rp-intro-mini-ads {
  position: absolute;
  inset: 10px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(2, 1fr);
  gap: 5px;
}
.rp-intro-mini-ad {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  animation: rpIntroAdUnlock 3.6s ease-in-out infinite;
}
.rp-intro-mini-ad:nth-child(1) { animation-delay: 0.0s;  }
.rp-intro-mini-ad:nth-child(2) { animation-delay: 0.25s; }
.rp-intro-mini-ad:nth-child(3) { animation-delay: 0.5s;  }
.rp-intro-mini-ad:nth-child(4) { animation-delay: 0.75s; }
.rp-intro-mini-ad:nth-child(5) { animation-delay: 1.0s;  }
.rp-intro-mini-ad:nth-child(6) { animation-delay: 1.25s; }
@keyframes rpIntroAdUnlock {
  0%, 10% {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: none;
  }
  45%, 85% {
    background: linear-gradient(135deg, var(--rp-primary) 0%, var(--rp-primary-bright) 100%);
    border-color: rgba(91, 155, 255, 0.7);
    box-shadow: 0 0 10px rgba(43, 127, 255, 0.65);
  }
  100% {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: none;
  }
}

/* ---------- Industry chips row ---------- */
.rp-intro-chips {
  padding: 12px 28px 20px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px 8px;
  justify-content: center;
}
.rp-intro-chips-label {
  color: rgba(255, 255, 255, 0.4);
  font-family: var(--rp-font-mono);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-size: 0.625rem;
  margin-right: 4px;
}
.rp-intro-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 11px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 999px;
  color: rgba(255, 255, 255, 0.78);
  font-weight: 500;
  font-size: 0.75rem;
}
.rp-intro-chip--soon {
  color: var(--rp-primary-glow);
  border-color: rgba(91, 155, 255, 0.35);
  background: rgba(43, 127, 255, 0.1);
}

/* ---------- Footer CTA ---------- */
.rp-intro-footer {
  padding: 8px 28px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.rp-intro-start {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  max-width: 320px;
  padding: 15px 26px;
  background: linear-gradient(135deg, var(--rp-primary-bright) 0%, var(--rp-primary) 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 12px;
  font-family: inherit;
  font-size: 0.9375rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  cursor: pointer;
  overflow: hidden;
  animation: rpIntroBreathe 2.4s ease-in-out infinite;
  transition: transform 0.2s;
}
.rp-intro-start:hover {
  transform: translateY(-2px);
  animation-play-state: paused;
  box-shadow: 0 16px 44px rgba(43, 127, 255, 0.55);
}
.rp-intro-start:active { transform: translateY(0); }
@keyframes rpIntroBreathe {
  0%, 100% {
    box-shadow: 0 4px 16px rgba(43, 127, 255, 0.45), 0 0 0 0 rgba(43, 127, 255, 0.45);
  }
  50% {
    box-shadow: 0 8px 28px rgba(43, 127, 255, 0.6), 0 0 0 8px rgba(43, 127, 255, 0);
  }
}
.rp-intro-start::before {
  content: "";
  position: absolute;
  top: 0;
  left: -80%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.4) 50%, transparent 100%);
  transform: skewX(-20deg);
  animation: rpIntroShine 3s ease-in-out infinite;
  pointer-events: none;
}
@keyframes rpIntroShine {
  0%, 100%  { left: -80%; }
  55%, 100% { left: 160%; }
}
.rp-intro-start-text, .rp-intro-start-arrow { position: relative; z-index: 1; }
.rp-intro-start-arrow {
  font-size: 1.125rem;
  transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}
.rp-intro-start:hover .rp-intro-start-arrow { transform: translateX(5px); }

.rp-intro-skip {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.38);
  font-size: 0.75rem;
  font-weight: 500;
  cursor: pointer;
  padding: 4px 8px;
  font-family: inherit;
  letter-spacing: 0.02em;
  transition: color 0.2s;
}
.rp-intro-skip:hover { color: rgba(255, 255, 255, 0.8); }

/* ---------- Responsive ---------- */
@media (max-width: 520px) {
  .rp-intro-header   { padding: 26px 20px 4px; }
  .rp-intro-previews { padding: 18px 16px 6px; }
  .rp-intro-chips    { padding: 10px 20px 16px; }
  .rp-intro-footer   { padding: 4px 20px 24px; }
  .rp-intro-title    { font-size: 1.625rem; }
  .rp-intro-subtitle { font-size: 0.875rem; }
  .rp-intro-preview-visual { width: 64px; height: 64px; }
}

/* END: WELCOME-INTRO STYLES */

</style>
</head>

