:root {
  --rp-primary:        #0052CC;
  --rp-primary-dark:   #003D99;
  --rp-primary-bright: #2B7FFF;
  --rp-primary-glow:   #5B9BFF;
  --rp-primary-light:  #E8F0FF;
  --rp-success:        #10B981;
  --rp-ink-900:        #0A1628;
  --rp-ink-800:        #111E33;
  --rp-ink-700:        #1E293B;
  --rp-ink-500:        #475569;
  --rp-ink-400:        #64748B;
  --rp-ink-200:        #CBD5E1;
  --rp-ink-100:        #E2E8F0;
  --rp-ink-25:         #F8FAFC;
  --rp-font-display:   -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
